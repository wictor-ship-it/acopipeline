# BFF (Node) env — holds the OAuth secret. Copy to `server/.env` and fill.
# NEVER commit the filled file; NEVER expose these to the SPA/browser.
# See design_handoff_fase1/phase2/01-google-gmail-calendar-setup.md

# From Google Cloud → Credentials → OAuth client (Web application), step §5
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/auth/google/callback

# Stage 2a — read-only scopes (default). For Stage 2b writes, append:
#   https://www.googleapis.com/auth/gmail.send
#   https://www.googleapis.com/auth/calendar.events
# (also add them on the Google Cloud consent screen, then re-connect). The write
# routes 403 with "reconnect_needed" until the scope is granted.
OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/calendar.readonly

# Random secrets you generate locally (e.g. `openssl rand -base64 32`)
SESSION_SECRET=
TOKEN_ENCRYPTION_KEY=

# Service
PORT=8787
ALLOWED_ORIGIN=http://localhost:5173

# Agent brain (independent of Google — the app runs the mock agent without it).
# Key from console.anthropic.com. Model: claude-sonnet-5 (default) or claude-opus-4-8.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
